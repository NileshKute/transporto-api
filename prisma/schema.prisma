generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CEO
  MANAGER
  ACCOUNTANT
  DRIVER
  COLD_STORAGE_OPERATOR
  VIEWER
}

enum VehicleType {
  TRUCK
  MINI_TRUCK
  TRAILER
  REEFER_TRUCK
  REEFER_PICKUP
  TANKER
  PICKUP
  VAN
  TEMPO
  CONTAINER
}

enum FuelType {
  DIESEL
  PETROL
  CNG
  ELECTRIC
  HYBRID
}

enum VehicleStatus {
  ACTIVE
  IN_MAINTENANCE
  IDLE
  BREAKDOWN
  SOLD
  DECOMMISSIONED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  ON_LEAVE
  OFF_DUTY
  TERMINATED
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LoadStatus {
  LOADED
  EMPTY
  PARTIAL
}

enum EntrySource {
  MANUAL
  WHATSAPP
  WHATSAPP_OCR
  MOBILE_APP
  AUTO_SENSOR
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CREDIT
  COMPANY_ACCOUNT
}

enum MaintenanceType {
  SCHEDULED_SERVICE
  ENGINE_REPAIR
  TIRE_REPLACEMENT
  BRAKE_SERVICE
  OIL_CHANGE
  ELECTRICAL
  BODY_WORK
  AC_REPAIR
  CLUTCH
  GEAR_BOX
  SUSPENSION
  BATTERY
  RADIATOR
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EmergencyType {
  PUNCTURE
  ACCIDENT
  BREAKDOWN
  ENGINE_FAILURE
  FUEL_EMPTY
  ELECTRICAL_FAILURE
  BRAKE_FAILURE
  FIRE
  THEFT
  OTHER
}

enum EmergencyStatus {
  PENDING
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InsuranceType {
  COMPREHENSIVE
  THIRD_PARTY
  ZERO_DEP
  OD_ONLY
}

enum InsuranceStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  CLAIMED
  CANCELLED
}

enum DocumentType {
  RC
  FITNESS
  PERMIT
  PUC
  TAX_RECEIPT
  INSURANCE_COPY
  ROAD_TAX
  NATIONAL_PERMIT
  STATE_PERMIT
  OTHER
}

enum ColdStorageType {
  COLD_ROOM
  CHILLER
  DEEP_FREEZER
  BLAST_FREEZER
  RIPENING_CHAMBER
}

enum ColdStorageStatus {
  NORMAL
  WARNING
  CRITICAL
  OFFLINE
  MAINTENANCE
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum WhatsAppMessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum NotificationType {
  INSURANCE_EXPIRY
  LICENSE_EXPIRY
  FITNESS_EXPIRY
  MAINTENANCE_DUE
  EMERGENCY_REPORTED
  COLD_STORAGE_ALERT
  TRIP_COMPLETED
  FUEL_ANOMALY
  DOCUMENT_EXPIRY
  SYSTEM
}

enum LedgerEntryType {
  SALARY
  ADVANCE
  ADVANCE_RECOVERY
  EXTRA_DUTY
  BONUS
  ALLOWANCE
  PENALTY
  FOOD
  FUEL_ADVANCE
  TOLL
  MAINTENANCE
  OTHER
}

enum SalaryStatus {
  PENDING
  CALCULATED
  APPROVED
  PAID
  PARTIAL
}

enum BillingType {
  MONTHLY_CONTRACT
  ADHOC
  MIXED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

// ==================== MODELS ====================

model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  phone     String?  @unique @db.VarChar(20)
  password  String
  role      UserRole @default(DRIVER)
  avatarUrl String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver    Driver?
  auditLogs AuditLog[]
  sessions  Session[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Vehicle {
  id              String        @id @default(uuid())
  regNumber       String        @unique @db.VarChar(20)
  type            VehicleType
  make            String        @db.VarChar(50)
  model           String        @db.VarChar(50)
  variant         String?       @db.VarChar(100)
  year            Int
  fuelType        FuelType      @default(DIESEL)
  status          VehicleStatus @default(ACTIVE)
  currentKm       Float         @default(0)
  chassisNumber   String?       @db.VarChar(50)
  engineNumber    String?       @db.VarChar(50)
  color           String?       @db.VarChar(30)
  bodyType        String?       @db.VarChar(50)
  normsType       String?       @db.VarChar(80)
  cubicCapacity   String?       @db.VarChar(32)
  numberOfCylinders Int?
  seatingCapacity Int?
  sleeperCapacity Int?
  standingCapacity Int?
  wheelbase       Int?
  unladenWeight   Int?
  grossVehicleWeight Int?
  loadCapacityKg  Float?
  numTires        Int?
  tankCapacityL   Float?
  purchaseDate    DateTime?
  purchasePrice   Float?
  photoUrl        String?
  notes           String?
  isDeleted       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Vehicle Identity
  ownerName           String?
  fatherName          String?
  ownerAddress        String?
  ownerCount          Int?
  registrationDate    DateTime?
  rcNumber            String?
  registrationAuthority String?   @db.VarChar(120)
  vehicleCategory     String?   @db.VarChar(32)
  vehicleClassDesc    String?   @db.VarChar(160)
  rcStatus            String?   @db.VarChar(32)

  // PUC (Pollution Under Control)
  pucNumber           String?
  pucIssueDate        DateTime?
  pucExpiryDate       DateTime?
  pucCertificateUrl   String?

  // Insurance (on-vehicle)
  insurancePolicyNumber   String?
  insuranceCompany        String?
  insuranceStartDate      DateTime?
  insuranceExpiryDate     DateTime?
  insuranceCertificateUrl String?
  insuranceType           String?

  financer                String?   @db.VarChar(120)
  isFinanced              Boolean   @default(false)

  // Fitness Certificate
  fitnessNumber         String?
  fitnessIssueDate      DateTime?
  fitnessExpiryDate     DateTime?
  fitnessCertificateUrl String?

  // Road Tax
  taxReceiptNumber    String?
  taxPaidDate         DateTime?
  taxExpiryDate       DateTime?
  taxReceiptUrl       String?
  taxAmount           Float?

  // Permit
  permitNumber        String?
  permitType          String?
  permitIssueDate     DateTime?
  permitValidFrom     DateTime?
  permitExpiryDate    DateTime?
  permitUrl           String?

  blacklistStatus     String?   @db.VarChar(200)
  nonUseStatus        String?   @db.VarChar(200)
  nonUseFrom          DateTime?
  nonUseTo            DateTime?
  nocDetails          String?   @db.Text

  // GeoTrackers / live GPS snapshot (updated by sync or jobs)
  lastLatitude    Float?
  lastLongitude   Float?
  lastSpeed       Float?
  lastTemperature Float?
  lastGpsUpdate   DateTime?
  gpsStatus       String?    @default("UNKNOWN")
  iconType        String     @default("reefer_truck") // truck icon for GPS map display

  trips           Trip[]
  fuelEntries     FuelEntry[]
  maintenance          Maintenance[]
  vehicleMaintRecords  VehicleMaintRecord[]
  emergencies     Emergency[]
  insurance       Insurance[]
  shifts          Shift[]
  documents       VehicleDocument[]
  assignments     DriverVehicleAssignment[]
  clientVehicles  ClientVehicle[]
  gpsLive         GpsLive[]
  gpsHistory      GpsHistory[]
  gpsShareSessions GpsShareSession[]
  dailyTripLogs   DailyTripLog[]

  @@index([regNumber])
  @@index([status])
  @@index([type])
  @@map("vehicles")
}

model Driver {
  id               String       @id @default(uuid())
  userId           String?      @unique
  user             User?        @relation(fields: [userId], references: [id])
  name             String       @db.VarChar(100)
  nickname         String?      @db.VarChar(100)
  phone            String       @unique @db.VarChar(20)
  altPhone         String?      @db.VarChar(20)
  licenseNumber    String       @unique @db.VarChar(30)
  licenseType      String?      @db.VarChar(20)
  licenseExpiry    DateTime
  dateOfBirth      DateTime?
  bloodGroup       String?      @db.VarChar(5)
  experience       Int          @default(0)
  status           DriverStatus @default(AVAILABLE)
  address          String?
  city             String?      @db.VarChar(50)
  state            String?      @db.VarChar(50)
  pincode          String?      @db.VarChar(10)
  emergencyContact String?      @db.VarChar(20)
  emergencyName    String?      @db.VarChar(100)
  photoUrl         String?
  aadharNumber     String?      @db.VarChar(20)
  panNumber        String?      @db.VarChar(15)
  bankAccount      String?      @db.VarChar(20)
  bankIfsc         String?      @db.VarChar(15)
  salary           Float?
  rating           Float        @default(4.0)
  totalTrips       Int          @default(0)
  totalKm          Float        @default(0)
  joiningDate      DateTime     @default(now())
  isDeleted        Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  baseSalary       Decimal?  @db.Decimal(12, 2)
  employeeCode     String?   @db.VarChar(20)

  trips            Trip[]
  fuelEntries      FuelEntry[]
  emergencies      Emergency[]
  shifts           Shift[]
  whatsappMessages WhatsAppMessage[]
  assignments      DriverVehicleAssignment[]
  attendances      DriverAttendance[]
  ledgerEntries    DriverLedger[]
  salaryRecords    DriverSalary[]
  dailyTripLogs    DailyTripLog[]

  @@index([phone])
  @@index([licenseNumber])
  @@index([status])
  @@map("drivers")
}

model DriverVehicleAssignment {
  id           String    @id @default(uuid())
  driverId     String
  driver       Driver    @relation(fields: [driverId], references: [id])
  vehicleId    String
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id])
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  isCurrent    Boolean   @default(true)

  @@index([driverId, isCurrent])
  @@index([vehicleId, isCurrent])
  @@map("driver_vehicle_assignments")
}

model DriverAttendance {
  id       String           @id @default(uuid())
  driverId String
  driver   Driver           @relation(fields: [driverId], references: [id])
  date     DateTime         @db.Date
  status   AttendanceStatus @default(PRESENT)
  checkIn  DateTime?
  checkOut DateTime?
  notes    String?

  @@unique([driverId, date])
  @@map("driver_attendance")
}

model Trip {
  id            String     @id @default(uuid())
  tripNumber    String     @unique @db.VarChar(20)
  vehicleId     String
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])
  driverId      String
  driver        Driver     @relation(fields: [driverId], references: [id])
  date          DateTime   @db.Date
  startKm       Float
  endKm         Float?
  distanceKm    Float?
  startLocation String     @db.VarChar(100)
  endLocation   String?    @db.VarChar(100)
  startLat      Float?
  startLng      Float?
  endLat        Float?
  endLng        Float?
  status        TripStatus @default(IN_PROGRESS)
  loadStatus    LoadStatus @default(LOADED)
  cargoType     String?
  cargoWeight   Float?
  cargoUnit     String?
  clientName    String?
  lrNumber      String?
  billAmount    Float?
  tollAmount    Float?
  otherExpenses Float?
  startTime     DateTime?
  endTime       DateTime?
  notes         String?
  source        EntrySource @default(MANUAL)

  expenses TripExpense[]

  @@index([vehicleId])
  @@index([driverId])
  @@index([date])
  @@index([status])
  @@index([tripNumber])
  @@map("trips")
}

/// One row per vehicle per work day; multiple stops as DailyTripEntry
model DailyTripLog {
  id          String    @id @default(uuid())
  date        DateTime  @db.Date
  driverId    String?
  driver      Driver?   @relation(fields: [driverId], references: [id], onDelete: SetNull)
  driverName  String
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  vehicleReg  String
  trips       DailyTripEntry[]
  notes       String?
  source      String    @default("MANUAL")
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([date, vehicleReg])
  @@index([date])
  @@index([driverId])
  @@index([vehicleId])
  @@map("daily_trip_logs")
}

model DailyTripEntry {
  id             String       @id @default(uuid())
  dailyTripLogId String
  dailyTripLog   DailyTripLog @relation(fields: [dailyTripLogId], references: [id], onDelete: Cascade)
  sequence       Int
  fromLocation   String
  toLocation     String
  clientName     String?
  tripType       String       @default("DELIVERY")
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([dailyTripLogId])
  @@map("daily_trip_entries")
}

model TripExpense {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type        String   @db.VarChar(50)
  amount      Float
  description String?
  receiptUrl  String?
  date        DateTime @db.Date

  @@map("trip_expenses")
}

model FuelEntry {
  id           String      @id @default(uuid())
  entryNumber  String      @unique @db.VarChar(20)
  vehicleId    String
  vehicle      Vehicle     @relation(fields: [vehicleId], references: [id])
  driverId     String
  driver       Driver      @relation(fields: [driverId], references: [id])
  date         DateTime    @db.Date
  fuelType     FuelType    @default(DIESEL)
  liters       Float
  ratePerLiter Float?
  totalCost    Float
  odometer     Float
  fuelStation  String?     @db.VarChar(150)
  location     String?
  isFull       Boolean     @default(true)
  receiptUrl   String?
  receiptNo    String?
  paymentMode  PaymentMode @default(CASH)
  source       EntrySource @default(MANUAL)
  notes        String?
  createdAt    DateTime    @default(now())

  @@index([vehicleId])
  @@index([driverId])
  @@index([date])
  @@map("fuel_entries")
}

model FuelAverage {
  id          String   @id @default(uuid())
  vehicleId   String
  period      String   @db.VarChar(10)
  totalKm     Float
  totalLiters Float
  avgKmPerL   Float
  totalCost   Float
  costPerKm   Float
  entries     Int
  calculatedAt DateTime @default(now())

  @@unique([vehicleId, period])
  @@map("fuel_averages")
}

model Maintenance {
  id                String            @id @default(uuid())
  vehicleId         String
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id])
  type              MaintenanceType
  subType           String?           @db.VarChar(50)
  description       String?
  cost              Float             @default(0)
  laborCost         Float?
  partsCost         Float?
  date              DateTime          @db.Date
  completedDate     DateTime?
  status            MaintenanceStatus @default(SCHEDULED)
  priority          Priority          @default(MEDIUM)
  garage            String?
  garagePhone       String?
  mechanicName      String?
  odometerAtService Float?
  nextDueDate       DateTime?
  nextDueKm         Float?
  warrantyExpiry    DateTime?
  invoiceNo         String?
  invoiceUrl        String?
  photoUrls         String[]
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([vehicleId])
  @@index([status])
  @@index([nextDueDate])
  @@map("maintenance")
}

/// Configurable maintenance kinds for truck vs reefer (separate from enum MaintenanceType on legacy Maintenance model)
model MaintCatalog {
  id        String                @id @default(uuid())
  name      String
  category  String
  icon      String?
  isActive  Boolean               @default(true)
  sortOrder Int                   @default(0)
  records   VehicleMaintRecord[]
  createdAt DateTime              @default(now())

  @@unique([name, category])
  @@map("maintenance_types")
}

model VehicleMaintRecord {
  id               String       @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  typeId           String
  type             MaintCatalog @relation(fields: [typeId], references: [id])
  category         String
  date             DateTime
  description      String?      @db.Text
  partsUsed        String?      @db.Text
  laborCost        Float        @default(0)
  partsCost        Float        @default(0)
  totalCost        Float        @default(0)
  odometerKm       Int?
  runningHours     Int?
  garageName       String?
  garageContact    String?
  billNumber       String?
  billPhotoUrl     String?
  nextServiceDate  DateTime?
  nextServiceKm    Int?
  nextServiceHours Int?
  notes            String?      @db.Text
  source           String       @default("MANUAL")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([vehicleId])
  @@index([date])
  @@index([category])
  @@index([typeId])
  @@map("maintenance_records")
}

model Emergency {
  id            String          @id @default(uuid())
  vehicleId     String
  vehicle       Vehicle         @relation(fields: [vehicleId], references: [id])
  driverId      String
  driver        Driver          @relation(fields: [driverId], references: [id])
  type          EmergencyType
  description   String
  location      String?         @db.VarChar(200)
  latitude      Float?
  longitude     Float?
  date          DateTime        @db.Date
  time          String?         @db.VarChar(10)
  status        EmergencyStatus @default(PENDING)
  priority      Priority        @default(HIGH)
  photoUrls     String[]
  estimatedCost Float?
  actualCost    Float?
  source        EntrySource     @default(MANUAL)
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([date])
  @@map("emergencies")
}

model Insurance {
  id           String          @id @default(uuid())
  vehicleId    String
  vehicle      Vehicle         @relation(fields: [vehicleId], references: [id])
  provider     String          @db.VarChar(100)
  policyNumber String          @unique @db.VarChar(50)
  type         InsuranceType
  coverAmount  Float?
  premium      Float
  startDate    DateTime        @db.Date
  endDate      DateTime        @db.Date
  status       InsuranceStatus @default(ACTIVE)
  agentName    String?
  agentPhone   String?
  documentUrl  String?
  claimHistory Json?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([vehicleId])
  @@index([endDate])
  @@index([status])
  @@map("insurance")
}

model VehicleDocument {
  id          String       @id @default(uuid())
  vehicleId   String
  vehicle     Vehicle      @relation(fields: [vehicleId], references: [id])
  type        DocumentType
  documentNo  String?
  documentUrl String
  issuedDate  DateTime?
  expiryDate  DateTime?
  notes       String?
  createdAt   DateTime     @default(now())

  @@index([vehicleId])
  @@index([expiryDate])
  @@map("vehicle_documents")
}

model ColdStorageUnit {
  id            String            @id @default(uuid())
  name          String            @db.VarChar(100)
  type          ColdStorageType
  targetTemp    Float
  minTemp       Float?
  maxTemp       Float?
  capacityTotal Float
  capacityUnit  String            @default("Tons")
  location      String?
  status        ColdStorageStatus @default(NORMAL)
  sensorId      String?           @db.VarChar(50)
  isActive      Boolean           @default(true)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  temperatureLogs TemperatureLog[]
  storageClients  StorageClient[]
  alerts          ColdStorageAlert[]

  @@map("cold_storage_units")
}

model TemperatureLog {
  id          String          @id @default(uuid())
  unitId      String
  unit        ColdStorageUnit @relation(fields: [unitId], references: [id])
  temperature Float
  humidity    Float?
  doorStatus  String?
  powerStatus String?
  recordedBy  String?         @db.VarChar(50)
  recordedAt  DateTime        @default(now())

  @@index([unitId, recordedAt])
  @@index([recordedAt])
  @@map("temperature_logs")
}

model StorageClient {
  id          String          @id @default(uuid())
  unitId      String
  unit        ColdStorageUnit @relation(fields: [unitId], references: [id])
  clientName  String          @db.VarChar(100)
  clientPhone String?         @db.VarChar(20)
  productType String?         @db.VarChar(100)
  spaceUsed   Float
  ratePerUnit Float?
  startDate   DateTime        @db.Date
  endDate     DateTime?       @db.Date
  isActive    Boolean         @default(true)
  notes       String?
  createdAt   DateTime        @default(now())

  @@map("storage_clients")
}

model ColdStorageAlert {
  id          String          @id @default(uuid())
  unitId      String
  unit        ColdStorageUnit @relation(fields: [unitId], references: [id])
  alertType   String          @db.VarChar(50)
  message     String
  temperature Float?
  severity    Priority        @default(HIGH)
  isResolved  Boolean         @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime        @default(now())

  @@index([unitId, isResolved])
  @@index([createdAt])
  @@map("cold_storage_alerts")
}

model Shift {
  id          String      @id @default(uuid())
  driverId    String
  driver      Driver      @relation(fields: [driverId], references: [id])
  vehicleId   String?
  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id])
  date        DateTime    @db.Date
  startTime   DateTime
  endTime     DateTime?
  status      ShiftStatus @default(SCHEDULED)
  hoursWorked Float?
  overtime    Float?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([driverId, date])
  @@index([vehicleId])
  @@index([date])
  @@map("shifts")
}

model Client {
  id               String    @id @default(uuid())
  name             String    @db.VarChar(200)
  address          String?   @db.Text
  gstNumber        String?   @db.VarChar(20)
  contactPerson    String?   @db.VarChar(100)
  contactPhone     String?   @db.VarChar(20)
  contactEmail     String?   @db.VarChar(150)
  billingType       BillingType @default(MIXED)
  contractRate      Decimal?  @db.Decimal(12, 2)
  adhocTripRate     Decimal?  @db.Decimal(12, 2)
  paymentTermsDays  Int       @default(15)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  invoices         Invoice[]
  clientVehicles   ClientVehicle[]
  gpsShareSessions GpsShareSession[]
  locations        Location[]

  @@index([isActive])
  @@map("clients")
}

model Location {
  id         String   @id @default(uuid())
  name       String   @unique
  shortName  String?
  type       String   @default("GENERAL")
  city       String?
  state      String?
  address    String?
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([name])
  @@index([type])
  @@index([isActive])
  @@map("locations")
}

model ClientVehicle {
  id          String      @id @default(uuid())
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id])
  vehicleId   String
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id])
  billingType BillingType @default(MONTHLY_CONTRACT)
  monthlyRate Decimal?    @db.Decimal(12, 2)
  tripRate    Decimal?    @db.Decimal(12, 2)
  route       String?     @db.VarChar(200)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([clientId, vehicleId])
  @@index([clientId])
  @@index([vehicleId])
  @@map("client_vehicles")
}

model Invoice {
  id                 String    @id @default(uuid())
  invoiceNumber      String    @unique @db.VarChar(30)
  clientId           String
  client             Client    @relation(fields: [clientId], references: [id])
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  issueDate          DateTime  @default(now())
  dueDate            DateTime
  status             InvoiceStatus @default(DRAFT)
  subtotal           Decimal   @db.Decimal(12, 2) @default(0)
  totalDeductions    Decimal   @db.Decimal(12, 2) @default(0)
  totalAmount        Decimal   @db.Decimal(12, 2) @default(0)
  amountPaid         Decimal   @db.Decimal(12, 2) @default(0)
  balanceDue         Decimal   @db.Decimal(12, 2) @default(0)
  amountInWords      String?   @db.Text
  notes              String?   @db.Text
  pdfUrl             String?   @db.VarChar(500)
  lineItems          InvoiceLineItem[]
  deductions         InvoiceDeduction[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([billingPeriodStart, billingPeriodEnd])
  @@map("invoices")
}

model InvoiceLineItem {
  id               String   @id @default(uuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  vehicleId        String?   @db.VarChar(50)
  vehicleRegNumber String   @db.VarChar(20)
  description      String   @db.VarChar(300)
  billingType      BillingType @default(MONTHLY_CONTRACT)
  tripCount        Int      @default(0)
  daysCount        Float?
  rate             Decimal  @db.Decimal(12, 2) @default(0)
  weight           Decimal?  @db.Decimal(12, 2) @default(0)
  advance          Decimal  @db.Decimal(12, 2) @default(0)
  amount           Decimal  @db.Decimal(12, 2) @default(0)
  createdAt        DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model InvoiceDeduction {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String   @db.VarChar(200)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_deductions")
}

model WhatsAppMessage {
  id                String                    @id @default(uuid())
  driverId          String?
  driver            Driver?                   @relation(fields: [driverId], references: [id])
  fromPhone         String                    @db.VarChar(50)
  toPhone           String?                   @db.VarChar(50)
  direction         WhatsAppMessageDirection  @default(INBOUND)
  message           String                    @db.Text
  mediaUrl          String?                   @db.Text
  parsedType        String?
  parsedData        Json?
  confidence        Float?
  confidenceScore   Float                     @default(0)
  status            MessageStatus             @default(RECEIVED)
  errorReason       String?
  processedAt       DateTime?
  twilioSid         String?
  twilioMessageSid  String?                   @db.VarChar(100)
  twilioStatus      String?                   @db.VarChar(50)
  autoReplyText     String?                   @db.Text
  receivedAt        DateTime                  @default(now())

  @@index([driverId])
  @@index([fromPhone])
  @@index([receivedAt])
  @@index([status])
  @@map("whatsapp_messages")
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String
  entity    String?          @db.VarChar(50)
  entityId  String?
  priority  Priority         @default(MEDIUM)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  forRole   UserRole?
  forUserId String?
  createdAt DateTime         @default(now())

  @@index([forUserId, isRead])
  @@index([forRole, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   @db.VarChar(20)
  entity    String   @db.VarChar(50)
  entityId  String?  @db.VarChar(50)
  oldData   Json?
  newData   Json?
  ipAddress String?  @db.VarChar(45)
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique @db.VarChar(50)
  value String
  group String @db.VarChar(30)
  label String @db.VarChar(100)

  @@map("settings")
}

model Permission {
  id        String    @id @default(uuid())
  role      String    @db.VarChar(32)
  module    String    @db.VarChar(64)
  action    String    @db.VarChar(32)
  allowed   Boolean   @default(false)
  ownOnly   Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([role, module, action], name: "permission_role_module_action_key")
  @@index([role])
  @@index([module])
  @@map("permissions")
}

model PermissionTemplate {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permission_templates")
}

model DriverLedger {
  id            String          @id @default(uuid())
  driverId      String
  driver        Driver          @relation(fields: [driverId], references: [id])
  date          DateTime
  type          LedgerEntryType
  category      String?         @db.VarChar(50)
  description   String          @db.Text
  amount        Decimal         @db.Decimal(12, 2)
  isCredit      Boolean
  balanceAfter  Decimal?        @db.Decimal(12, 2)
  tripId        String?
  approvedBy    String?
  notes         String?         @db.Text
  month         Int?
  year          Int?
  isPaid        Boolean         @default(false)
  paidDate      DateTime?
  paidMode      String?
  paidRef       String?
  paidBy        String?
  paidNotes     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([driverId])
  @@index([driverId, date])
  @@index([driverId, month, year])
  @@index([type])
  @@map("driver_ledger")
}

model DriverSalary {
  id            String       @id @default(uuid())
  driverId      String
  driver        Driver       @relation(fields: [driverId], references: [id])
  month         Int
  year          Int
  baseSalary    Decimal      @db.Decimal(12, 2)
  totalAdvances Decimal      @db.Decimal(12, 2) @default(0)
  extraDutyPay  Decimal      @db.Decimal(12, 2) @default(0)
  bonuses       Decimal      @db.Decimal(12, 2) @default(0)
  penalties     Decimal      @db.Decimal(12, 2) @default(0)
  otherCredits  Decimal      @db.Decimal(12, 2) @default(0)
  otherDebits   Decimal      @db.Decimal(12, 2) @default(0)
  netPayable    Decimal      @db.Decimal(12, 2) @default(0)
  status        SalaryStatus @default(PENDING)
  paidAmount    Decimal      @db.Decimal(12, 2) @default(0)
  paidDate      DateTime?
  paymentMode   String?
  transactionRef String?
  paidBy        String?
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([driverId, month, year])
  @@index([driverId])
  @@index([month, year])
  @@index([status])
  @@map("driver_salaries")
}

model BpclTransaction {
  id              String    @id @default(uuid())
  txnId           String    @unique
  txnDate         DateTime
  txnTime         String?
  cardNumber      String
  cardName        String?
  vehicleNumber   String
  vehicleId       String?
  mobileNumber    String?
  product         String
  litres          Float
  rate            Float
  amount          Float
  totalAmount     Float
  stationName     String?
  stationId       String?
  stationCity     String?
  stationState    String?
  txnMode         String?
  txnType         String?
  txnCategory     String?
  creditDebit     String?
  slipNumber      String?
  importBatchId   String?
  source          String    @default("BPCL_SMARTFLEET")
  createdAt       DateTime  @default(now())

  @@index([txnDate])
  @@index([cardNumber])
  @@index([vehicleNumber])
  @@index([importBatchId])
  @@map("bpcl_transactions")
}

model BpclCard {
  id              String           @id @default(uuid())
  cardNumber      String           @unique
  vehicleNumber   String
  vehicleId       String?
  cardName        String?
  currentTag      String           @default("BUSINESS")
  notes           String?          @db.Text
  periods         BpclCardPeriod[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([vehicleNumber])
  @@map("bpcl_cards")
}

model BpclCardPeriod {
  id        String    @id @default(uuid())
  cardId    String
  card      BpclCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  tag       String
  startDate DateTime
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([cardId])
  @@index([startDate])
  @@map("bpcl_card_periods")
}

// ============================================
// GPS LIVE — one row per GeoTracker device (upsert)
// ============================================
model GpsLive {
  id              String    @id @default(uuid())
  vehicleId       String?
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  geoTrackerKey   String    @unique
  regNumber       String
  latitude        Float
  longitude       Float
  speed           Float     @default(0)
  direction       Int       @default(0)
  temperature     Float?
  ignitionOn      Boolean   @default(false)
  acOn            Boolean   @default(false)
  doorOpen        Boolean   @default(false)
  status          String    @default("UNKNOWN")
  haltedSince     String?
  movingSince     String?
  noDataSince     String?
  location        String?
  elevation       Float?
  bmStr           String?
  rawAnalogData   String?
  deviceTimestamp DateTime?
  lastSyncAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([vehicleId])
  @@index([regNumber])
  @@index([status])
  @@map("gps_live")
}

// ============================================
// GPS HISTORY — append-only pings
// ============================================
model GpsHistory {
  id              String    @id @default(uuid())
  vehicleId       String?
  vehicle         Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  geoTrackerKey   String
  regNumber       String
  latitude        Float
  longitude       Float
  speed           Float     @default(0)
  direction       Int       @default(0)
  temperature     Float?
  ignitionOn      Boolean   @default(false)
  acOn            Boolean   @default(false)
  status          String    @default("UNKNOWN")
  haltedSince     String?
  movingSince     String?
  location        String?
  bmStr           String?
  rawAnalogData   String?
  deviceTimestamp DateTime?
  recordedAt      DateTime  @default(now())

  @@index([vehicleId, recordedAt])
  @@index([regNumber, recordedAt])
  @@index([recordedAt])
  @@map("gps_history")
}

// ============================================
// GPS SHARE — public live tracking by token
// ============================================
model GpsShareSession {
  id        String    @id @default(uuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  token     String    @unique @default(uuid())
  label     String?
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([token])
  @@index([vehicleId])
  @@index([isActive])
  @@map("gps_share_sessions")
}
